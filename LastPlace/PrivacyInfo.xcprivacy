<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	NOTE: this manifest predates the Supabase/Google Sign-In/Sign in with
	Apple work and is now out of date -- the app sends account data (email,
	user ID) to Supabase and uses the GoogleSignIn-iOS SDK, neither of which
	is declared below yet. This needs a real pass (NSPrivacyCollectedDataTypes
	entries, third-party SDK manifests) before the next App Store submission;
	tracked as a cross-cutting item in the roadmap doc. Left minimal for now
	beyond removing the no-longer-true CloudKit claim.

	The one "required reason API" currently declared: UserDefaults, used by
	AppearanceSettingsStore, AppLockSettingsStore, and
	UserDefaultsOnboardingPreferences to persist simple local preferences.
	Reason CA92.1 covers reading/writing UserDefaults data that's only ever
	accessed by this app (and its App Group, for the widget) — not shared
	with or readable by any other developer's app.
	-->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
